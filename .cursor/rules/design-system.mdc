# Freelance OS — Design System Rules (CLAUDE.md)

This document defines the design system for the **Freelance OS** dashboard application. All values are extracted directly from the live UI implementation — treat this as the single source of truth for any agent building new screens or components.

---

## 1. Design Tokens (CSS Variables)

The token system has two layers that work together:

1. **shadcn base tokens** — the source of truth for all color values. Defined once in `:root` and `.dark`. Never edit values anywhere else.
2. **`--c-*` semantic aliases** — shorthand aliases that point to shadcn tokens via `var()`. Used throughout component code for brevity and clarity. They automatically inherit light/dark mode because they reference shadcn tokens, not raw values.

**Rule:** Always define values in shadcn tokens. Always consume them via `--c-*` aliases in component CSS.

---

### Layer 1 — shadcn Base Tokens

Add this to your global stylesheet (e.g. `globals.css`). This is the only place raw `oklch()` values should appear.

```css
@import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;1,9..144,400&family=Outfit:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap');

:root {
  /* ── Surfaces ── */
  --background:             oklch(1 0 0);
  --foreground:             oklch(0.141 0.005 285.823);
  --card:                   oklch(1 0 0);
  --card-foreground:        oklch(0.141 0.005 285.823);
  --popover:                oklch(1 0 0);
  --popover-foreground:     oklch(0.141 0.005 285.823);

  /* ── Brand / Primary — green-teal ── */
  --primary:                oklch(0.60 0.13 163);
  --primary-foreground:     oklch(0.98 0.02 166);

  /* ── Secondary / Muted surfaces ── */
  --secondary:              oklch(0.967 0.001 286.375);
  --secondary-foreground:   oklch(0.21 0.006 285.885);
  --muted:                  oklch(0.967 0.001 286.375);
  --muted-foreground:       oklch(0.552 0.016 285.938);
  --accent:                 oklch(0.967 0.001 286.375);
  --accent-foreground:      oklch(0.21 0.006 285.885);

  /* ── Destructive / Error ── */
  --destructive:            oklch(0.577 0.245 27.325);
  --destructive-foreground: oklch(0.98 0 0);

  /* ── Borders & Inputs ── */
  --border:                 oklch(0.92 0.004 286.32);
  --input:                  oklch(0.92 0.004 286.32);
  --ring:                   oklch(0.705 0.015 286.067);

  /* ── Radius ── */
  --radius:                 0.625rem; /* 10px base */

  /* ── Charts — green monochromatic scale ── */
  --chart-1:                oklch(0.85 0.13 165);
  --chart-2:                oklch(0.77 0.15 163);
  --chart-3:                oklch(0.70 0.15 162);
  --chart-4:                oklch(0.60 0.13 163);
  --chart-5:                oklch(0.51 0.10 166);

  /* ── Sidebar ── */
  --sidebar:                oklch(0.985 0 0);
  --sidebar-foreground:     oklch(0.141 0.005 285.823);
  --sidebar-primary:        oklch(0.60 0.13 163);
  --sidebar-primary-foreground: oklch(0.98 0.02 166);
  --sidebar-accent:         oklch(0.967 0.001 286.375);
  --sidebar-accent-foreground: oklch(0.21 0.006 285.885);
  --sidebar-border:         oklch(0.92 0.004 286.32);
  --sidebar-ring:           oklch(0.705 0.015 286.067);

  /* ── Freelance OS supplemental — status/priority ── */
  --status-active:          oklch(0.60 0.13 163);   /* = --primary */
  --status-review:          oklch(0.75 0.18 65);    /* amber */
  --status-overdue:         oklch(0.577 0.245 27.325); /* = --destructive */
  --priority-high:          oklch(0.577 0.245 27.325);
  --priority-medium:        oklch(0.75 0.18 65);
  --priority-low:           oklch(0.60 0.13 163);
}

.dark {
  --background:             oklch(0.141 0.005 285.823);
  --foreground:             oklch(0.985 0 0);
  --card:                   oklch(0.21 0.006 285.885);
  --card-foreground:        oklch(0.985 0 0);
  --popover:                oklch(0.21 0.006 285.885);
  --popover-foreground:     oklch(0.985 0 0);
  --primary:                oklch(0.70 0.15 162);
  --primary-foreground:     oklch(0.26 0.05 173);
  --secondary:              oklch(0.274 0.006 286.033);
  --secondary-foreground:   oklch(0.985 0 0);
  --muted:                  oklch(0.274 0.006 286.033);
  --muted-foreground:       oklch(0.705 0.015 286.067);
  --accent:                 oklch(0.274 0.006 286.033);
  --accent-foreground:      oklch(0.985 0 0);
  --destructive:            oklch(0.704 0.191 22.216);
  --destructive-foreground: oklch(0.98 0 0);
  --border:                 oklch(1 0 0 / 10%);
  --input:                  oklch(1 0 0 / 15%);
  --ring:                   oklch(0.552 0.016 285.938);
  --chart-1:                oklch(0.85 0.13 165);
  --chart-2:                oklch(0.77 0.15 163);
  --chart-3:                oklch(0.70 0.15 162);
  --chart-4:                oklch(0.60 0.13 163);
  --chart-5:                oklch(0.51 0.10 166);
  --sidebar:                oklch(0.21 0.006 285.885);
  --sidebar-foreground:     oklch(0.985 0 0);
  --sidebar-primary:        oklch(0.77 0.15 163);
  --sidebar-primary-foreground: oklch(0.26 0.05 173);
  --sidebar-accent:         oklch(0.274 0.006 286.033);
  --sidebar-accent-foreground: oklch(0.985 0 0);
  --sidebar-border:         oklch(1 0 0 / 10%);
  --sidebar-ring:           oklch(0.552 0.016 285.938);

  /* Dark mode: status/priority re-mapped to dark primary/destructive */
  --status-active:          oklch(0.70 0.15 162);   /* = dark --primary */
  --status-overdue:         oklch(0.704 0.191 22.216);
  --priority-high:          oklch(0.704 0.191 22.216);
  --priority-low:           oklch(0.70 0.15 162);
}
```

